<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета светлой темы -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#F5F7FA"/>
    <SolidColorBrush x:Key="ForegroundColor" Color="#2C3E50"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#3498DB"/>
    <SolidColorBrush x:Key="ButtonHover" Color="#2980B9"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#E74C3C"/>
    <SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>
    <SolidColorBrush x:Key="InfoColor" Color="#3498DB"/>

</ResourceDictionary>