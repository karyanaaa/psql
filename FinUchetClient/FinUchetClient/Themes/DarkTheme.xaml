<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета тёмной темы -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#2D2D30"/>
    <SolidColorBrush x:Key="ForegroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackground" Color="#3E3E42"/>
    <SolidColorBrush x:Key="BorderColor" Color="#555555"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#252526"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#0E639C"/>
    <SolidColorBrush x:Key="ButtonHover" Color="#1177BB"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#6A9955"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#F14C4C"/>
    <SolidColorBrush x:Key="WarningColor" Color="#DCDCAA"/>
    <SolidColorBrush x:Key="InfoColor" Color="#3794FF"/>

</ResourceDictionary>