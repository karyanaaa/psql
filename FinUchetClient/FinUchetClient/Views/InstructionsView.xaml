<UserControl x:Class="FinUchetClient.Views.InstructionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <ScrollViewer>
        <StackPanel Margin="30">
            <TextBlock Text="📖 Как пользоваться приложением" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="1️⃣ Регистрация и вход" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• При первом запуске нажмите 'Зарегистрироваться'" Margin="15,0,0,5"/>
                    <TextBlock Text="• Введите имя пользователя, пароль (мин. 4 символа) и контрольный вопрос" Margin="15,0,0,5"/>
                    <TextBlock Text="• Контрольный вопрос нужен для восстановления пароля" Margin="15,0,0,5"/>
                    <TextBlock Text="• После регистрации войдите с созданными данными" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="2️⃣ Управление операциями" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• В разделе 'Операции' вы видите все свои доходы и расходы" Margin="15,0,0,5"/>
                    <TextBlock Text="• Введите сумму, выберите тип, категорию, укажите описание и дату" Margin="15,0,0,5"/>
                    <TextBlock Text="• Для редактирования: выберите операцию → нажмите 'Редактировать'" Margin="15,0,0,5"/>
                    <TextBlock Text="• Для удаления: выберите операцию → нажмите 'Удалить'" Margin="15,0,0,5"/>
                    <TextBlock Text="• Используйте фильтры для поиска по дате, типу или описанию" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="3️⃣ Категории" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• Создавайте свои категории доходов и расходов для удобного учета" Margin="15,0,0,5"/>
                    <TextBlock Text="• Введите название, выберите тип (Доход/Расход) и нажмите 'Добавить'" Margin="15,0,0,5"/>
                    <TextBlock Text="• Для редактирования нажмите '✏️' рядом с категорией" Margin="15,0,0,5"/>
                    <TextBlock Text="• Внимание: при удалении категории все связанные операции также удаляются" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="4️⃣ Инвестиции" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• Добавляйте свои инвестиции (акции, облигации, криптовалюта и т.д.)" Margin="15,0,0,5"/>
                    <TextBlock Text="• Укажите название, тип, количество, цену покупки и текущую цену" Margin="15,0,0,5"/>
                    <TextBlock Text="• Приложение автоматически рассчитает прибыль/убыток" Margin="15,0,0,5"/>
                    <TextBlock Text="• Отслеживайте общую доходность портфеля на панели статистики" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="5️⃣ Статистика и отчеты" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• Выберите период для анализа (даты начала и конца)" Margin="15,0,0,5"/>
                    <TextBlock Text="• Круговая диаграмма показывает структуру расходов по категориям" Margin="15,0,0,5"/>
                    <TextBlock Text="• График динамики показывает изменение доходов/расходов по месяцам" Margin="15,0,0,5"/>
                    <TextBlock Text="• Экспортируйте отчеты в CSV или Excel для дальнейшего анализа" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="6️⃣ Полезное" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• Калькулятор накоплений: рассчитайте, сколько сможете накопить" Margin="15,0,0,5"/>
                    <TextBlock Text="• Конвертер валют: переводите деньги в разные валюты" Margin="15,0,0,5"/>
                    <TextBlock Text="• Советы по экономии и инвестициям для повышения финансовой грамотности" Margin="15,0,0,5"/>
                    <TextBlock Text="• Финансовый чек-лист для самопроверки" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="7️⃣ Обратная связь" FontSize="18" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                    <TextBlock Text="• Задайте вопрос администратору через раздел 'Обратная связь'" Margin="15,0,0,5"/>
                    <TextBlock Text="• Укажите тему и текст сообщения, затем отправьте" Margin="15,0,0,5"/>
                    <TextBlock Text="• Администратор ответит, и вы увидите ответ в том же разделе" Margin="15,0,0,5"/>
                    <TextBlock Text="• Если есть ответ от администратора — он отобразится в таблице" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Background="#2C3E50" Padding="20" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="💡 Полезные советы" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock Text="• Регулярно записывайте операции — это ключ к контролю финансов" Foreground="#BDC3C7" Margin="15,0,0,5"/>
                    <TextBlock Text="• Используйте категории для детального анализа трат" Foreground="#BDC3C7" Margin="15,0,0,5"/>
                    <TextBlock Text="• Откладывайте 10-20% дохода — это создаст финансовую подушку" Foreground="#BDC3C7" Margin="15,0,0,5"/>
                    <TextBlock Text="• Экспортируйте отчеты для архива или анализа в Excel" Foreground="#BDC3C7" Margin="15,0,0,5"/>
                    <TextBlock Text="• Следите за динамикой доходов и расходов через графики" Foreground="#BDC3C7" Margin="15,0,0,5"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>