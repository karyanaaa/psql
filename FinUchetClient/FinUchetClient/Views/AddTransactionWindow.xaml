<Window x:Class="FinUchetClient.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление операции"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel>
            <!-- Заголовок -->
            <TextBlock x:Name="TitleText" 
                      FontSize="22" 
                      FontWeight="Bold" 
                      Foreground="#2C3E50"
                      Margin="0,0,0,20"/>

            <!-- Сумма -->
            <TextBlock Text="Сумма" Foreground="#7F8C8D" Margin="0,0,0,5"/>
            <TextBox x:Name="AmountBox" 
                     Padding="10" 
                     FontSize="14"
                     PreviewTextInput="AmountBox_PreviewTextInput"/>

            <!-- Категория -->
            <TextBlock Text="Категория" Foreground="#7F8C8D" Margin="0,15,0,5"/>
            <ComboBox x:Name="CategoryBox" 
                      Padding="10" 
                      FontSize="14"
                      DisplayMemberPath="Name"/>

            <!-- Описание -->
            <TextBlock Text="Описание" Foreground="#7F8C8D" Margin="0,15,0,5"/>
            <TextBox x:Name="DescriptionBox" 
                     Padding="10" 
                     FontSize="14"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MinLines="2"/>

            <!-- Дата -->
            <TextBlock Text="Дата" Foreground="#7F8C8D" Margin="0,15,0,5"/>
            <DatePicker x:Name="DatePicker" 
                        Padding="10" 
                        FontSize="14"/>

            <!-- Кнопки -->
            <Grid Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="Отмена"
                        Background="#95A5A6"
                        Foreground="White"
                        Padding="10"
                        Margin="0,0,5,0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        Content="Сохранить"
                        x:Name="SaveButton"
                        Background="#3498DB"
                        Foreground="White"
                        Padding="10"
                        Margin="5,0,0,0"
                        Click="SaveButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>