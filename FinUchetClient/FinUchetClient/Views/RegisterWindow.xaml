<Window x:Class="FinUchetClient.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="700" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border CornerRadius="10" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопка закрытия -->
            <Button Grid.Row="0" 
                    Content="✕" 
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Foreground="#7F8C8D"
                    BorderThickness="0"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="CloseButton_Click"
                    Width="30" Height="30"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center">
                    <!-- Заголовок -->
                    <TextBlock Text="📝 Регистрация" 
                              FontSize="28" 
                              FontWeight="Bold" 
                              HorizontalAlignment="Center" 
                              Margin="0,0,0,20"
                              Foreground="#2C3E50"/>

                    <!-- Имя пользователя -->
                    <TextBlock Text="Имя пользователя" 
                              FontSize="12" 
                              Foreground="#7F8C8D"/>
                    <TextBox x:Name="UsernameBox" 
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,5,0,0"
                             BorderBrush="#DDD"
                             BorderThickness="1"/>

                    <!-- Email (опционально) -->
                    <TextBlock Text="Email (необязательно)" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,15,0,0"/>
                    <TextBox x:Name="EmailBox" 
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,5,0,0"
                             BorderBrush="#DDD"
                             BorderThickness="1"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,15,0,0"/>
                    <PasswordBox x:Name="PasswordBox"
                                Padding="12,10"
                                FontSize="14"
                                Margin="0,5,0,0"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                PasswordChanged="PasswordBox_PasswordChanged"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="Подтверждение пароля" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,15,0,0"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                Padding="12,10"
                                FontSize="14"
                                Margin="0,5,0,0"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <!-- Контрольный вопрос -->
                    <TextBlock Text="Контрольный вопрос" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,15,0,0"/>
                    <ComboBox x:Name="SecurityQuestionBox" 
                              Padding="12,10"
                              FontSize="14"
                              Margin="0,5,0,0"
                              BorderBrush="#DDD"
                              BorderThickness="1">
                        <ComboBoxItem Content="Какую кличку у вас было в детстве?"/>
                        <ComboBoxItem Content="Как звали вашего первого питомца?"/>
                        <ComboBoxItem Content="Название вашей первой школы?"/>
                        <ComboBoxItem Content="Любимый цвет в детстве?"/>
                        <ComboBoxItem Content="Имя вашего лучшего друга из детства?"/>
                    </ComboBox>

                    <!-- Ответ -->
                    <TextBlock Text="Ответ" 
                              FontSize="12" 
                              Foreground="#7F8C8D"
                              Margin="0,15,0,0"/>
                    <TextBox x:Name="SecurityAnswerBox" 
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,5,0,0"
                             BorderBrush="#DDD"
                             BorderThickness="1"/>

                    <!-- Требования к паролю -->
                    <Border Background="#F8F9FA" 
                            CornerRadius="5" 
                            Padding="10"
                            Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="Требования к паролю:" 
                                      FontSize="11" 
                                      FontWeight="Bold"
                                      Foreground="#2C3E50"
                                      Margin="0,0,0,5"/>
                            <TextBlock Text="• Минимум 4 символа" 
                                      FontSize="11" 
                                      Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <!-- Ошибка -->
                    <TextBlock x:Name="ErrorText" 
                              Foreground="#E74C3C" 
                              Margin="0,15,0,0"
                              TextWrapping="Wrap"
                              FontSize="12"
                              Visibility="Collapsed"/>

                    <!-- Кнопка регистрации -->
                    <Button x:Name="RegisterButton"
                            Content="Зарегистрироваться"
                            Background="#2ECC71"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Padding="12,10"
                            Margin="0,15,0,0"
                            Click="RegisterButton_Click"/>

                    <!-- Кнопка возврата к входу -->
                    <Button Content="← Назад к входу"
                            Background="Transparent"
                            Foreground="#3498DB"
                            BorderThickness="0"
                            FontSize="12"
                            Margin="0,10,0,0"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>