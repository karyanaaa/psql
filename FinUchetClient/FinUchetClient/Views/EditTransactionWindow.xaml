<Window x:Class="FinUchetClient.Views.EditTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование операции"
        Width="450" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="10" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопка закрытия -->
            <Button Grid.Row="0" 
                    Content="✕" 
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="#7F8C8D"
                    BorderThickness="0"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="CloseButton_Click"
                    Width="30" Height="30" Margin="370,0,0,0"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="✏️ Редактирование операции" 
                          FontSize="22" 
                          FontWeight="Bold" 
                          Foreground="#2C3E50"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"/>

                <!-- Сумма -->
                <TextBlock Text="💰 Сумма" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="AmountBox" 
                         FontSize="14" 
                         Padding="10" 
                         Margin="0,0,0,15"
                         BorderBrush="#DDD"
                         BorderThickness="1"/>

                <!-- Тип операции -->
                <TextBlock Text="📌 Тип операции" Foreground="#666" Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeBox" FontSize="14" Padding="10" Margin="0,0,0,15">
                    <ComboBoxItem Content="💰 Доход"/>
                    <ComboBoxItem Content="💸 Расход"/>
                </ComboBox>

                <!-- Категория -->
                <TextBlock Text="📁 Категория" Foreground="#666" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryBox" 
                          FontSize="14" 
                          Padding="10" 
                          Margin="0,0,0,15"
                          DisplayMemberPath="Name"/>

                <!-- Описание -->
                <TextBlock Text="📝 Описание" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionBox" 
                         FontSize="14" 
                         Padding="10" 
                         Margin="0,0,0,15"
                         BorderBrush="#DDD"
                         BorderThickness="1"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="80"/>

                <!-- Дата -->
                <TextBlock Text="📅 Дата" Foreground="#666" Margin="0,0,0,5"/>
                <DatePicker x:Name="DatePicker" 
                            FontSize="14" 
                            Padding="10" 
                            Margin="0,0,0,20"/>

                <!-- Кнопки -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Content="Отмена"
                            Height="40"
                            FontSize="14"
                            Background="#95A5A6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            Click="CancelButton_Click"/>

                    <Button Grid.Column="1" 
                            Content="Сохранить"
                            Height="40"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="10,0,0,0"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>