<UserControl x:Class="FinUchetClient.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📁 Управление категориями" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBlock Text="Создавайте и редактируйте категории доходов и расходов" 
                           FontSize="13" 
                           Foreground="#7F8C8D"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Статистика категорий -->
        <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#E8F8F5" Padding="15" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💰 Доходы" Foreground="#27AE60" FontSize="14"/>
                        <TextBlock x:Name="IncomeCategoriesCount" FontSize="24" FontWeight="Bold" Foreground="#27AE60" Text="0"/>
                        <TextBlock Text="категорий" FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FEF5E8" Padding="15" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📉 Расходы" Foreground="#E67E22" FontSize="14"/>
                        <TextBlock x:Name="ExpenseCategoriesCount" FontSize="24" FontWeight="Bold" Foreground="#E67E22" Text="0"/>
                        <TextBlock Text="категорий" FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Панель добавления категории -->
        <Border Grid.Row="2" Background="White" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <WrapPanel>
                <TextBox x:Name="NewCategoryName" Width="220" Height="35" Margin="0,0,10,0" ToolTip="Название категории" FontSize="14"/>

                <ComboBox x:Name="NewCategoryType" Width="120" Height="35" Margin="0,0,10,0" FontSize="14">
                    <ComboBoxItem Content="💰 Доход"/>
                    <ComboBoxItem Content="💸 Расход"/>
                </ComboBox>

                <Button Content="➕ Добавить категорию" Width="140" Height="35" Background="#2ECC71" Foreground="White" Click="AddCategory_Click" FontSize="13"/>
              
            </WrapPanel>
        </Border>

        <!-- Список категорий -->
        <DataGrid Grid.Row="3" 
                  x:Name="CategoriesGrid"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Background="White"
                  RowHeight="40"
                  FontSize="13"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F9FA"/>
    </Grid>
</UserControl>