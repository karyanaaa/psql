<UserControl x:Class="FinUchetClient.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,20" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="👑 Панель администратора" 
                           FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Управление пользователями, просмотр данных и статистика" 
                           FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="20" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 Список пользователей" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <DataGrid x:Name="UsersGrid" 
                          Grid.Row="1"
                          AutoGenerateColumns="True" 
                          IsReadOnly="True" 
                          RowHeight="40" 
                          FontSize="12" 
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8F9FA" 
                          SelectionChanged="UsersGrid_SelectionChanged"
                          Height="300"
                          Margin="0,0,0,15"/>

                <TabControl Grid.Row="2" Margin="0,15,0,15">
                    <TabItem Header="👤 Информация">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                            <StackPanel Margin="10">
                                <TextBlock x:Name="UserDetailsText" 
                                           Text="Выберите пользователя" 
                                           FontSize="13" 
                                           Foreground="#666"
                                           TextWrapping="Wrap"/>

                                <Separator Margin="0,15,0,15"/>

                                <TextBlock Text="📊 Статистика пользователя" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#E8F8F5" Padding="10" Margin="0,0,5,0" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="💰 Всего доходов" FontSize="11" Foreground="#27AE60"/>
                                            <TextBlock x:Name="UserTotalIncome" Text="0 ₽" FontSize="16" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#FEF5E8" Padding="10" Margin="5,0,0,0" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="📉 Всего расходов" FontSize="11" Foreground="#E67E22"/>
                                            <TextBlock x:Name="UserTotalExpense" Text="0 ₽" FontSize="16" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Background="#E8F4FD" Padding="10" Margin="0,10,0,0" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="💰 Инвестиционный портфель" FontSize="12" FontWeight="Bold" Foreground="#2980B9"/>
                                        <TextBlock Text="Всего вложено:" FontSize="11"/>
                                        <TextBlock x:Name="UserTotalInvested" Text="0 ₽" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock Text="Текущая стоимость:" FontSize="11" Margin="0,5,0,0"/>
                                        <TextBlock x:Name="UserCurrentValue" Text="0 ₽" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
                                    <Button Content="📊 Экспорт данных" 
                                            Background="#3498DB" Foreground="White" 
                                            Padding="10" Click="ExportUserData_Click" 
                                            Margin="0,0,10,0" FontSize="12"/>
                                    <Button Content="✉️ Уведомление" 
                                            Background="#9B59B6" Foreground="White" 
                                            Padding="10" Click="SendNotification_Click" 
                                            FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="📋 Транзакции">
                        <DataGrid x:Name="UserTransactionsGrid" 
                                  AutoGenerateColumns="True" 
                                  IsReadOnly="True" 
                                  RowHeight="35" 
                                  FontSize="11"
                                  MaxHeight="400"
                                  Margin="5"/>
                    </TabItem>

                    <TabItem Header="💰 Инвестиции">
                        <DataGrid x:Name="UserInvestmentsGrid" 
                                  AutoGenerateColumns="True" 
                                  IsReadOnly="True" 
                                  RowHeight="35" 
                                  FontSize="11"
                                  MaxHeight="400"
                                  Margin="5"/>
                    </TabItem>

                    <TabItem Header="✉️ Сообщения">
                        <DataGrid x:Name="UserMessagesGrid" 
                                  AutoGenerateColumns="True" 
                                  IsReadOnly="True" 
                                  RowHeight="35" 
                                  FontSize="11"
                                  MaxHeight="400"
                                  Margin="5"/>
                    </TabItem>
                </TabControl>

                <Border Grid.Row="3" Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="⚙️ Управление пользователем" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                        <TextBlock x:Name="SelectedUserText" Text="Пользователь не выбран" Foreground="#7F8C8D" Margin="0,0,0,15"/>

                        <WrapPanel>
                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,15,15" Width="280">
                                <StackPanel>
                                    <TextBlock Text="🔑 Смена пароля" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <PasswordBox x:Name="NewPasswordBox" Height="30" Margin="0,0,0,10"/>
                                    <PasswordBox x:Name="ConfirmNewPasswordBox" Height="30" Margin="0,0,0,10"/>
                                    <Button Content="🔄 Сменить пароль" Background="#3498DB" Foreground="White" 
                                            Padding="8" Click="ChangeUserPassword_Click" Height="35"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,15,15" Width="250">
                                <StackPanel>
                                    <TextBlock Text="🔒 Блокировка" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="BlockTimeComboBox" Height="30" Margin="0,0,0,10">
                                        <ComboBoxItem Content="На 1 час" Tag="1"/>
                                        <ComboBoxItem Content="На 3 часа" Tag="3"/>
                                        <ComboBoxItem Content="На 6 часов" Tag="6"/>
                                        <ComboBoxItem Content="На 12 часов" Tag="12"/>
                                        <ComboBoxItem Content="На 24 часа" Tag="24"/>
                                        <ComboBoxItem Content="На 3 дня" Tag="72"/>
                                        <ComboBoxItem Content="На 7 дней" Tag="168"/>
                                        <ComboBoxItem Content="Навсегда" Tag="0"/>
                                    </ComboBox>
                                    <Button Content="🔒 Заблокировать" Background="#E74C3C" Foreground="White" 
                                            Padding="8" Click="BlockUser_Click" Height="35"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,15,15" Width="180">
                                <StackPanel>
                                    <TextBlock Text="🔓 Разблокировка" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Button Content="🔓 Разблокировать" Background="#2ECC71" Foreground="White" 
                                            Padding="8" Click="UnblockUser_Click" Height="35"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15" Width="180">
                                <StackPanel>
                                    <TextBlock Text="🗑️ Удаление" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Button Content="🗑️ Удалить" Background="#C0392B" Foreground="White" 
                                            Padding="8" Click="DeleteUser_Click" Height="35"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Background="White" Padding="15" CornerRadius="8" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="✉️ Сообщения от пользователей" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                <DataGrid x:Name="MessagesGrid" AutoGenerateColumns="True" IsReadOnly="True" 
                                          RowHeight="40" FontSize="12" GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F8F9FA" Height="200"
                                          SelectionChanged="MessagesGrid_SelectionChanged"/>

                                <StackPanel Margin="0,15,0,0">
                                    <TextBlock Text="Ответ на сообщение:" Foreground="#666" Margin="0,0,0,5"/>
                                    <TextBox x:Name="ResponseBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                             Margin="0,0,0,10"/>
                                    <Button Content="📤 Отправить ответ" Width="150" Height="35" Background="#3498DB" 
                                            Foreground="White" Click="SendResponse_Click" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>