<UserControl x:Class="FinUchetClient.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📋 История операций" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Управляйте своими доходами и расходами" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель добавления операции -->
        <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <WrapPanel>
                <TextBox x:Name="NewAmountBox" Width="120" Height="35" Margin="0,0,10,0" Text="0" FontSize="14"/>
                <ComboBox x:Name="NewTypeBox" Width="100" Height="35" Margin="0,0,10,0" FontSize="14">
                    <ComboBoxItem Content="💰 Доход"/>
                    <ComboBoxItem Content="💸 Расход"/>
                </ComboBox>
                <TextBox x:Name="NewDescriptionBox" Width="180" Height="35" Margin="0,0,10,0" Text="Описание" FontSize="14"/>
                <ComboBox x:Name="NewCategoryBox" Width="130" Height="35" Margin="0,0,10,0" DisplayMemberPath="Name" FontSize="14"/>
                <DatePicker x:Name="NewDatePicker" Width="120" Height="35" Margin="0,0,10,0" FontSize="13"/>
                <Button Content="➕ Добавить" Width="100" Height="35" Background="#2ECC71" Foreground="White" Click="AddTransaction_Click" FontSize="13"/>
            </WrapPanel>
        </Border>

        <!-- Панель фильтров -->
        <Border Grid.Row="2" Background="White" Padding="15,10" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <WrapPanel>
                <TextBox x:Name="SearchBox" Width="150" Height="30" Margin="0,0,10,0" TextChanged="SearchBox_TextChanged" ToolTip="Поиск" FontSize="13"/>
                <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#7F8C8D"/>
                <DatePicker x:Name="DateFromPicker" Width="110" Height="30" Margin="0,0,10,0" SelectedDateChanged="DateFilter_Changed"/>
                <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#7F8C8D"/>
                <DatePicker x:Name="DateToPicker" Width="110" Height="30" Margin="0,0,10,0" SelectedDateChanged="DateFilter_Changed"/>
                <ComboBox x:Name="TypeFilterBox" Width="100" Height="30" Margin="0,0,10,0" SelectionChanged="TypeFilter_Changed">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="💰 Доход"/>
                    <ComboBoxItem Content="💸 Расход"/>
                </ComboBox>
                <Button Content="Очистить" Width="80" Height="30" Background="#95A5A6" Foreground="White" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <!-- Таблица операций -->
        <DataGrid Grid.Row="3" 
                  x:Name="TransactionsGrid"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Background="White"
                  RowHeight="40"
                  FontSize="12"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F9FA"
                  SelectionMode="Single"/>

        <!-- Информация о количестве -->
        <TextBlock x:Name="CountTextBlock" Grid.Row="4" HorizontalAlignment="Right" Margin="0,10,10,0" Foreground="#7F8C8D" FontSize="11"/>

        <!-- Кнопки действий внизу -->
        <Border Grid.Row="5" Background="White" Padding="15" Margin="0,15,0,0" CornerRadius="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✏️ Редактировать" Width="120" Height="35" Background="#3498DB" Foreground="White" Margin="0,0,10,0" Click="EditTransaction_Click" FontSize="13"/>
                <Button Content="🗑️ Удалить" Width="100" Height="35" Background="#E74C3C" Foreground="White" Click="DeleteTransaction_Click" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>