<Window x:Class="FinUchetClient.Views.EditInvestmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование инвестиции"
        Width="450" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="✏️ Редактирование инвестиции" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Название" Foreground="#666" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" FontSize="14" Padding="10" Margin="0,0,0,15"/>

            <TextBlock Text="Тип" Foreground="#666" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeBox" FontSize="14" Padding="10" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem Content="📈 Акции"/>
                <ComboBoxItem Content="📉 Облигации"/>
                <ComboBoxItem Content="₿ Криптовалюта"/>
                <ComboBoxItem Content="🏠 Недвижимость"/>
                <ComboBoxItem Content="🏦 Депозит"/>
            </ComboBox>

            <TextBlock Text="Количество" Foreground="#666" Margin="0,0,0,5"/>
            <TextBox x:Name="QuantityBox" FontSize="14" Padding="10" Margin="0,0,0,15"/>

            <TextBlock Text="Цена покупки (₽)" Foreground="#666" Margin="0,0,0,5"/>
            <TextBox x:Name="PurchasePriceBox" FontSize="14" Padding="10" Margin="0,0,0,15"/>

            <TextBlock Text="Текущая цена (₽)" Foreground="#666" Margin="0,0,0,5"/>
            <TextBox x:Name="CurrentPriceBox" FontSize="14" Padding="10" Margin="0,0,0,15"/>

            <Grid Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Отмена" Background="#95A5A6" Foreground="White" 
                        Padding="10" Margin="0,0,5,0" Click="CancelButton_Click"/>
                <Button Grid.Column="1" Content="Сохранить" Background="#3498DB" Foreground="White" 
                        Padding="10" Margin="5,0,0,0" Click="SaveButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>