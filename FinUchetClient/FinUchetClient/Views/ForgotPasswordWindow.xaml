<Window x:Class="FinUchetClient.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Восстановление пароля"
        Width="450" Height="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="10" Background="White" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center">
            <!-- Заголовок -->
            <TextBlock Text="🔐 Восстановление пароля" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Ответьте на контрольный вопрос, чтобы сбросить пароль" 
                       FontSize="12" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"
                       Foreground="#7F8C8D"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <!-- Имя пользователя -->
            <TextBlock Text="Имя пользователя" 
                       Margin="0,0,0,5" 
                       Foreground="#666"
                       FontSize="12"/>
            <TextBox x:Name="UsernameBox" 
                     Height="40"
                     FontSize="14"
                     Padding="12,10"
                     BorderBrush="#DDD"
                     BorderThickness="1"
                     Margin="0,0,0,15"
                     TextChanged="UsernameBox_TextChanged"/>

            <!-- Контрольный вопрос -->
            <TextBlock Text="Контрольный вопрос" 
                       Margin="0,0,0,5" 
                       Foreground="#666"
                       FontSize="12"/>
            <TextBox x:Name="SecurityQuestionBox" 
                     Height="40"
                     FontSize="14"
                     Padding="12,10"
                     BorderBrush="#DDD"
                     BorderThickness="1"
                     Margin="0,0,0,15"
                     IsReadOnly="True"
                     Background="#F8F9FA"/>

            <!-- Ответ -->
            <TextBlock Text="Ответ" 
                       Margin="0,0,0,5" 
                       Foreground="#666"
                       FontSize="12"/>
            <PasswordBox x:Name="AnswerBox" 
                         Height="40"
                         FontSize="14"
                         Padding="12,10"
                         BorderBrush="#DDD"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

            <!-- Новый пароль -->
            <TextBlock Text="Новый пароль" 
                       Margin="0,0,0,5" 
                       Foreground="#666"
                       FontSize="12"/>
            <PasswordBox x:Name="NewPasswordBox" 
                         Height="40"
                         FontSize="14"
                         Padding="12,10"
                         BorderBrush="#DDD"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

            <!-- Подтверждение пароля -->
            <TextBlock Text="Подтверждение пароля" 
                       Margin="0,0,0,5" 
                       Foreground="#666"
                       FontSize="12"/>
            <PasswordBox x:Name="ConfirmPasswordBox" 
                         Height="40"
                         FontSize="14"
                         Padding="12,10"
                         BorderBrush="#DDD"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="#E74C3C"
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Visibility="Collapsed"/>

            <!-- Кнопки -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="Отмена"
                        Height="40"
                        FontSize="14"
                        Background="#95A5A6"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        Content="Сбросить пароль"
                        Height="40"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="10,0,0,0"
                        Click="ResetButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>