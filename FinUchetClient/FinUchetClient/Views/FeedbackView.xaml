<UserControl x:Class="FinUchetClient.Views.FeedbackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,20" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="✉️ Обратная связь" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Задайте вопрос администратору" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,20" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Новое сообщение" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <TextBlock Text="Тема" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="SubjectBox" Padding="10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Сообщение" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="MessageText" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" FontSize="14" Margin="0,0,0,15"/>

                <Button Content="Отправить" Width="120" Height="35" Background="#2ECC71" Foreground="White" 
                        Click="SendMessage_Click" HorizontalAlignment="Right" FontSize="13"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="20" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Мои сообщения" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                <DataGrid x:Name="MessagesGrid" AutoGenerateColumns="True" IsReadOnly="True" 
                          RowHeight="40" FontSize="12" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8F9FA"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>