<UserControl x:Class="FinUchetClient.Views.UsefulView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="📚 ФИНАНСОВАЯ ГРАМОТНОСТЬ" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBlock Text="Советы, инструменты и вдохновение для управления деньгами" FontSize="14" Foreground="#7F8C8D" Margin="0,0,0,20"/>

            <!-- ========== РАЗДЕЛ 1: КАЛЬКУЛЯТОР НАКОПЛЕНИЙ ========== -->
            <Border Background="White" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💰 КАЛЬКУЛЯТОР НАКОПЛЕНИЙ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <TextBlock Text="Сумма в месяц:" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox x:Name="MonthlyAmountBox" Text="5000" FontSize="14" Padding="10" Margin="0,0,0,10"/>

                    <TextBlock Text="Период:" Foreground="#666" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PeriodValueBox" Grid.Column="0" Text="12" FontSize="14" Padding="10" TextAlignment="Center"/>
                        <ComboBox x:Name="PeriodUnitBox" Grid.Column="2" Width="100" Height="35" FontSize="14" SelectedIndex="1" Margin="10,0,0,0">
                            <ComboBoxItem Content="Дней"/>
                            <ComboBoxItem Content="Месяцев"/>
                            <ComboBoxItem Content="Лет"/>
                        </ComboBox>
                    </Grid>

                    <Button Content="Рассчитать накопления" Background="#3498DB" Foreground="White" Padding="10" Click="CalculateSavings_Click" Margin="0,0,0,10"/>

                    <TextBlock x:Name="SavingsResult" FontSize="16" FontWeight="Bold" Foreground="#27AE60" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SavingsDetail" FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
            <!-- ========== РАЗДЕЛ 2: КОНВЕРТЕР ВАЛЮТ ========== -->
            <Border Background="White" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💱 КОНВЕРТЕР ВАЛЮТ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <!-- Выбор валют для перевода -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Из валюты:" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox x:Name="FromCurrencyBox" Height="35" FontSize="14" SelectionChanged="Currency_SelectionChanged">
                                <ComboBoxItem Content="🇷🇺 RUB (Рубль)" Tag="RUB"/>
                                <ComboBoxItem Content="🇺🇸 USD (Доллар)" Tag="USD"/>
                                <ComboBoxItem Content="🇪🇺 EUR (Евро)" Tag="EUR"/>
                                <ComboBoxItem Content="🇰🇿 KZT (Тенге)" Tag="KZT"/>
                                <ComboBoxItem Content="🇬🇧 GBP (Фунт)" Tag="GBP"/>
                                <ComboBoxItem Content="🇨🇳 CNY (Юань)" Tag="CNY"/>
                                <ComboBoxItem Content="🇹🇷 TRY (Лиpa)" Tag="TRY"/>
                                <ComboBoxItem Content="🇦🇪 AED (Дирхам)" Tag="AED"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="→" FontSize="24" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="20,0,20,0"
                       Foreground="#3498DB"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="В валюту:" Foreground="#666" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ToCurrencyBox" Height="35" FontSize="14" SelectionChanged="Currency_SelectionChanged">
                                <ComboBoxItem Content="🇷🇺 RUB (Рубль)" Tag="RUB"/>
                                <ComboBoxItem Content="🇺🇸 USD (Доллар)" Tag="USD"/>
                                <ComboBoxItem Content="🇪🇺 EUR (Евро)" Tag="EUR"/>
                                <ComboBoxItem Content="🇰🇿 KZT (Тенге)" Tag="KZT"/>
                                <ComboBoxItem Content="🇬🇧 GBP (Фунт)" Tag="GBP"/>
                                <ComboBoxItem Content="🇨🇳 CNY (Юань)" Tag="CNY"/>
                                <ComboBoxItem Content="🇹🇷 TRY (Лиpa)" Tag="TRY"/>
                                <ComboBoxItem Content="🇦🇪 AED (Дирхам)" Tag="AED"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Ввод суммы -->
                    <TextBlock Text="Сумма:" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox x:Name="AmountToConvert" Text="1000" FontSize="14" Padding="10" Margin="0,0,0,10"/>

                    <!-- Кнопка конвертации -->
                    <Button Content="🔄 Конвертировать" Background="#3498DB" Foreground="White" 
                Padding="10" Click="ConvertCurrency_Click" Margin="0,0,0,10"/>

                    <!-- Результат -->
                    <Border Background="#E8F8F5" Padding="15" CornerRadius="8" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Результат:" FontWeight="Bold" Foreground="#27AE60" FontSize="14" Margin="0,0,0,5"/>
                            <TextBlock x:Name="ConversionResult" FontSize="20" FontWeight="Bold" Foreground="#27AE60" Text="0"/>
                            <TextBlock x:Name="ExchangeRateInfo" FontSize="11" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка обновления курсов -->
                    <Button Content="🔄 Обновить курсы валют" Background="#95A5A6" Foreground="White" 
                Padding="8" Margin="0,10,0,0" Click="UpdateRates_Click" FontSize="12"
                ToolTip="Обновить актуальные курсы валют из интернета"/>
                </StackPanel>
            </Border>
            <!-- ========== РАЗДЕЛ 2: ПРАВИЛА ЭКОНОМИИ ========== -->
            <Border Background="White" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💡 7 ЗОЛОТЫХ ПРАВИЛ ЭКОНОМИИ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="1️⃣ Ведите бюджет" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Записывайте все доходы и расходы. Вы удивитесь, куда уходят деньги!" TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="2️⃣ Правило 24 часов" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Перед крупной покупкой подождите сутки. Часто желание пропадает." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="3️⃣ Готовьте дома" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Обед из дома экономит до 10 000 ₽ в месяц по сравнению с кафе." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="4️⃣ Откажитесь от подписок" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Проверьте, какими сервисами вы реально пользуетесь. Отключите лишнее." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="5️⃣ Покупайте по списку" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="В магазин - только со списком. Это убережет от импульсивных трат." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="6️⃣ Копите сначала, тратьте потом" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="С зарплаты сначала отложите 10-20%, а остальное тратьте." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="7️⃣ Инвестируйте в себя" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Образование и навыки - лучшая инвестиция, которая всегда окупается." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== РАЗДЕЛ 3: СОВЕТЫ ПО ИНВЕСТИЦИЯМ ========== -->
            <Border Background="White" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📈 С ЧЕГО НАЧАТЬ ИНВЕСТИЦИИ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="✅ Шаг 1. Создайте финансовую подушку" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Накопите сумму на 3-6 месяцев жизни. Это ваша защита." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="✅ Шаг 2. Изучите основы" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Почитайте книги: 'Богатый папа, бедный папа', 'Самый богатый человек в Вавилоне'" TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="✅ Шаг 3. Начните с малого" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Инвестируйте даже 1000 ₽ в месяц. Регулярность важнее суммы." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="✅ Шаг 4. Диверсифицируйте" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Не кладите все яйца в одну корзину. Распределяйте риски." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="✅ Шаг 5. Будьте терпеливы" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Инвестиции - это марафон, а не спринт. Дайте деньгам время расти." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== РАЗДЕЛ 4: КНИГИ ПО ФИНАНСАМ ========== -->
            <Border Background="White" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📚 ТОП-5 КНИГ О ДЕНЬГАХ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="📖 «Богатый папа, бедный папа» — Роберт Кийосаки" FontWeight="Bold" Foreground="#E67E22"/>
                        <TextBlock Text="Меняет мышление о деньгах и активах." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="📖 «Самый богатый человек в Вавилоне» — Джордж Клейсон" FontWeight="Bold" Foreground="#E67E22"/>
                        <TextBlock Text="Классика финансовой грамотности в притчах." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="📖 «Думай и богатей» — Наполеон Хилл" FontWeight="Bold" Foreground="#E67E22"/>
                        <TextBlock Text="Философия успеха и достижения целей." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="📖 «Кофеин» — Михаил Джавадов" FontWeight="Bold" Foreground="#E67E22"/>
                        <TextBlock Text="Как маленькие траты крадут ваше богатство." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="📖 «Хватит мечтать, займись делом» — Барбара Шер" FontWeight="Bold" Foreground="#E67E22"/>
                        <TextBlock Text="Как найти призвание и зарабатывать любимым делом." TextWrapping="Wrap" Foreground="#666" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== РАЗДЕЛ 5: МОТИВАЦИЯ ========== -->
            <Border Background="#2C3E50" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🌟 МОТИВАЦИЯ НА СЕГОДНЯ" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10" TextAlignment="Center"/>
                    <TextBlock Text="«Не экономьте на том, что делает вас счастливым. Просто перестаньте тратить на то, что не имеет значения.»" Foreground="#FFFFFF" FontSize="14" FontStyle="Italic" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="— Уоррен Баффет" Foreground="#95A5A6" FontSize="12" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ========== РАЗДЕЛ 6: ФИНАНСОВЫЙ ЧЕК-ЛИСТ ========== -->
            <Border Background="White" Padding="20">
                <StackPanel>
                    <TextBlock Text="✅ ФИНАНСОВЫЙ ЧЕК-ЛИСТ" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <CheckBox Content="У меня есть финансовая подушка (3-6 месячных расходов)" Margin="0,5"/>
                    <CheckBox Content="Я веду учет доходов и расходов" Margin="0,5"/>
                    <CheckBox Content="Я откладываю 10-20% от каждого дохода" Margin="0,5"/>
                    <CheckBox Content="У меня нет потребительских кредитов" Margin="0,5"/>
                    <CheckBox Content="Я знаю свои финансовые цели на год вперед" Margin="0,5"/>
                    <CheckBox Content="Я инвестирую хотя бы 1000 ₽ в месяц" Margin="0,5"/>
                    <CheckBox Content="Я застрахован(а) (жизнь, здоровье, недвижимость)" Margin="0,5"/>
                    <CheckBox Content="У меня есть завещание или план наследства" Margin="0,5"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>